# Copy this file to .env and adjust it before running docker compose.

# Image and listener
VAULT_IMAGE=ghcr.io/willjallen/vault:latest
VAULT_BIND_ADDRESS=127.0.0.1
VAULT_PORT=8000
BASE_DOMAIN=localhost
VAULT_PUBLIC_URL=http://localhost:8000
VAULT_SITE_NAME=Vault
VAULT_DEV_MODE=0
VAULT_TTL_SWEEP_INTERVAL_SECONDS=60

# Required for production. Generate with: openssl rand -hex 32
VAULT_SESSION_SECRET=

# Auth mode: headers for a trusted reverse proxy, oidc for direct OIDC login.
VAULT_AUTH_MODE=headers
VAULT_BOOTSTRAP_ADMIN_EMAILS=
VAULT_ADMIN_GROUPS=admin,vault-admin
VAULT_HEADER_AUTH_ISSUER=headers

# OIDC settings, required only when VAULT_AUTH_MODE=oidc.
VAULT_OIDC_ISSUER=
VAULT_OIDC_CLIENT_ID=
VAULT_OIDC_CLIENT_SECRET=
VAULT_OIDC_SCOPES=openid email profile
VAULT_OIDC_REDIRECT_URI=
VAULT_OIDC_CLIENT_AUTH=client_secret_basic
VAULT_OIDC_GROUPS_CLAIM=groups
VAULT_OIDC_EMAIL_CLAIM=email
VAULT_OIDC_NAME_CLAIM=name
VAULT_OIDC_USERNAME_CLAIM=preferred_username

# Local storage uses the single /data volume by default.
VAULT_STORAGE_BACKEND=local
VAULT_STORAGE_PREFIX=

# S3-compatible storage, required only when VAULT_STORAGE_BACKEND=s3.
VAULT_S3_BUCKET=
VAULT_S3_REGION=us-east-1
VAULT_S3_ENDPOINT_URL=
VAULT_S3_ACCESS_KEY_ID=
VAULT_S3_SECRET_ACCESS_KEY=
VAULT_S3_SESSION_TOKEN=

# Cloudflare R2 storage, required only when VAULT_STORAGE_BACKEND=r2.
VAULT_R2_BUCKET=
VAULT_R2_ACCOUNT_ID=
VAULT_R2_ACCESS_KEY_ID=
VAULT_R2_SECRET_ACCESS_KEY=
VAULT_R2_ENDPOINT_URL=
